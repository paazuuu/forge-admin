<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.generator.mapper.BusinessQuantityLedgerMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.generator.domain.entity.AiBusinessQuantityLedger">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="operation_type" property="operationType"/>
        <result column="account_code" property="accountCode"/>
        <result column="item_code" property="itemCode"/>
        <result column="dimension_key" property="dimensionKey"/>
        <result column="quantity_delta" property="quantityDelta"/>
        <result column="balance_quantity" property="balanceQuantity"/>
        <result column="locked_quantity" property="lockedQuantity"/>
        <result column="target_account_code" property="targetAccountCode"/>
        <result column="target_item_code" property="targetItemCode"/>
        <result column="target_dimension_key" property="targetDimensionKey"/>
        <result column="source_object_code" property="sourceObjectCode"/>
        <result column="source_record_id" property="sourceRecordId"/>
        <result column="source_detail_id" property="sourceDetailId"/>
        <result column="lock_id" property="lockId"/>
        <result column="correlation_id" property="correlationId"/>
        <result column="idempotency_key" property="idempotencyKey"/>
        <result column="remark" property="remark"/>
        <result column="extra_data" property="extraData"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="create_dept" property="createDept"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Columns">
        id,
        tenant_id,
        operation_type,
        account_code,
        item_code,
        dimension_key,
        quantity_delta,
        balance_quantity,
        locked_quantity,
        target_account_code,
        target_item_code,
        target_dimension_key,
        source_object_code,
        source_record_id,
        source_detail_id,
        lock_id,
        correlation_id,
        idempotency_key,
        remark,
        extra_data,
        create_by,
        create_time,
        create_dept,
        update_by,
        update_time
    </sql>

    <select id="selectByIdempotencyKey" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM ai_business_quantity_ledger
        WHERE tenant_id = #{tenantId}
          AND idempotency_key = #{idempotencyKey}
        ORDER BY create_time DESC, id DESC
        LIMIT 1
    </select>

</mapper>
