package ${packageName}.${moduleName}.service.impl;

import cn.hutool.core.bean.BeanUtil;
import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
import com.baomidou.mybatisplus.extension.plugins.pagination.Page;
import com.baomidou.mybatisplus.extension.service.impl.ServiceImpl;
import ${packageName}.${moduleName}.dto.${className}DTO;
#if(${isMasterDetailLayout})
import ${packageName}.${moduleName}.dto.${className}MasterDetailDTO;
#end
import ${packageName}.${moduleName}.dto.${className}Query;
import ${packageName}.${moduleName}.entity.${className};
#foreach($table in $injectedRelatedTables)
import ${packageName}.${moduleName}.entity.${table.className};
#end
import ${packageName}.${moduleName}.mapper.${className}Mapper;
#foreach($table in $injectedRelatedTables)
import ${packageName}.${moduleName}.mapper.${table.className}Mapper;
#end
import ${packageName}.${moduleName}.service.I${className}Service;
import com.mdframe.forge.starter.core.domain.PageQuery;
import com.mdframe.forge.starter.trans.annotation.DictTranslate;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.apache.commons.lang3.StringUtils;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

/**
 * ${functionName}Service实现类
 * 
 * @author ${author}
 * @date ${datetime}
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class ${className}ServiceImpl extends ServiceImpl<${className}Mapper, ${className}> implements I${className}Service {

    private final ${className}Mapper ${classname}Mapper;
#foreach($table in $injectedRelatedTables)
    private final ${table.className}Mapper ${table.mapperVarName};
#end

    @Override
    @DictTranslate
    public Page<${className}> select${className}Page(PageQuery pageQuery, ${className}Query query) {
        log.info("分页查询参数:{}, 查询条件:{}", pageQuery, query);
        LambdaQueryWrapper<${className}> wrapper = buildQueryWrapper(query);
        return ${classname}Mapper.selectPage(pageQuery.toPage(), wrapper);
    }

    @Override
    @DictTranslate
    public List<${className}> select${className}List(${className}Query query) {
        log.info("查询参数:{}", query);
        LambdaQueryWrapper<${className}> wrapper = buildQueryWrapper(query);
        return ${classname}Mapper.selectList(wrapper);
    }

#if(${hasTreeConfig})
    @Override
    @DictTranslate
    public List<${tree.className}> select${tree.className}Tree(String loadMode, String parentValue) {
        LambdaQueryWrapper<${tree.className}> wrapper = new LambdaQueryWrapper<>();
        if ("lazy".equalsIgnoreCase(loadMode)) {
            if (StringUtils.isNotBlank(parentValue)) {
                wrapper.eq(${tree.className}::get${tree.parentFieldCap}, parentValue);
            } else {
                wrapper.and(item -> item.isNull(${tree.className}::get${tree.parentFieldCap})
                        .or().eq(${tree.className}::get${tree.parentFieldCap}, 0)
                        .or().eq(${tree.className}::get${tree.parentFieldCap}, "0"));
            }
            List<${tree.className}> rows = ${tree.mapperVarName}.selectList(wrapper);
            mark${tree.className}LeafState(rows);
            return rows;
        }
        List<${tree.className}> rows = ${tree.mapperVarName}.selectList(wrapper);
        return build${tree.className}Tree(rows);
    }

#end
    @Override
#if(${isMasterDetailLayout})
    @DictTranslate
    public Map<String, Object> select${className}ById(Long ${pkColumn.javaField}) {
        ${className} main = ${classname}Mapper.selectById(${pkColumn.javaField});
        Map<String, Object> result = new LinkedHashMap<>();
        result.put("main", main);
        Map<String, Object> children = new LinkedHashMap<>();
        if (main == null) {
            result.put("children", children);
            return result;
        }
#foreach($child in $masterDetailChildren)
        Object ${child.variableName}RelationValue = resolve${child.className}RelationValue(main, ${pkColumn.javaField});
        LambdaQueryWrapper<${child.className}> ${child.variableName}Wrapper = new LambdaQueryWrapper<>();
        ${child.variableName}Wrapper.eq(${child.className}::get${child.childFkFieldCap}, ${child.variableName}RelationValue);
        children.put("${child.childKey}", ${child.mapperVarName}.selectList(${child.variableName}Wrapper));
#end
        result.put("children", children);
        return result;
    }
#else
    public ${className} select${className}ById(Long ${pkColumn.javaField}) {
        return ${classname}Mapper.selectById(${pkColumn.javaField});
    }
#end

    @Override
    @Transactional(rollbackFor = Exception.class)
#if(${isMasterDetailLayout})
    public boolean insert${className}(${className}MasterDetailDTO dto) {
        ${className}DTO mainDto = dto == null || dto.getMain() == null ? new ${className}DTO() : dto.getMain();
        ${className} ${classname} = new ${className}();
        BeanUtil.copyProperties(mainDto, ${classname});
        boolean saved = ${classname}Mapper.insert(${classname}) > 0;
        if (!saved) {
            return false;
        }
#foreach($child in $masterDetailChildren)
        save${child.className}Rows(resolveChildRows(dto, "${child.childKey}"), resolve${child.className}RelationValue(${classname}, ${classname}.get${pkColumn.javaField.substring(0,1).toUpperCase()}${pkColumn.javaField.substring(1)}()));
#end
        return true;
    }
#else
    public boolean insert${className}(${className}DTO dto) {
        ${className} ${classname} = new ${className}();
        BeanUtil.copyProperties(dto, ${classname});
        return ${classname}Mapper.insert(${classname}) > 0;
    }
#end

    @Override
    @Transactional(rollbackFor = Exception.class)
#if(${isMasterDetailLayout})
    public boolean update${className}(${className}MasterDetailDTO dto) {
        if (dto == null || dto.getMain() == null) {
            return false;
        }
        ${className} ${classname} = new ${className}();
        BeanUtil.copyProperties(dto.getMain(), ${classname});
        boolean updated = ${classname}Mapper.updateById(${classname}) > 0;
        Object ${classname}Id = ${classname}.get${pkColumn.javaField.substring(0,1).toUpperCase()}${pkColumn.javaField.substring(1)}();
        if (${classname}Id == null) {
            return updated;
        }
        boolean childrenChanged = false;
#foreach($child in $masterDetailChildren)
        if (dto.getChildren() != null && dto.getChildren().containsKey("${child.childKey}")) {
            Object ${child.variableName}RelationValue = resolve${child.className}RelationValue(${classname}, ${classname}Id);
            clear${child.className}Rows(${child.variableName}RelationValue);
            save${child.className}Rows(resolveChildRows(dto, "${child.childKey}"), ${child.variableName}RelationValue);
            childrenChanged = true;
        }
#end
        return updated || childrenChanged;
    }
#else
    public boolean update${className}(${className}DTO dto) {
        ${className} ${classname} = new ${className}();
        BeanUtil.copyProperties(dto, ${classname});
        return ${classname}Mapper.updateById(${classname}) > 0;
    }
#end

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean delete${className}ById(Long ${pkColumn.javaField}) {
#if(${isMasterDetailLayout})
        ${className} ${classname} = ${classname}Mapper.selectById(${pkColumn.javaField});
        if (${classname} != null) {
#foreach($child in $masterDetailChildren)
            clear${child.className}Rows(resolve${child.className}RelationValue(${classname}, ${pkColumn.javaField}));
#end
        }
#end
        return ${classname}Mapper.deleteById(${pkColumn.javaField}) > 0;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean delete${className}ByIds(Long[] ${pkColumn.javaField}s) {
#if(${isMasterDetailLayout})
        if (${pkColumn.javaField}s == null || ${pkColumn.javaField}s.length == 0) {
            return false;
        }
        boolean result = true;
        for (Long ${pkColumn.javaField} : ${pkColumn.javaField}s) {
            result = delete${className}ById(${pkColumn.javaField}) && result;
        }
        return result;
#else
        return ${classname}Mapper.deleteBatchIds(Arrays.asList(${pkColumn.javaField}s)) > 0;
#end
    }

    /**
     * 构建查询条件
     */
    private LambdaQueryWrapper<${className}> buildQueryWrapper(${className}Query query) {
        LambdaQueryWrapper<${className}> wrapper = new LambdaQueryWrapper<>();
        if (query == null) {
            return wrapper;
        }
#foreach($column in $columns)
#if($column.isQuery == 1)
#if($column.queryType == 'EQ')
        wrapper.eq(query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}() != null, ${className}::get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}, query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}());
#elseif($column.queryType == 'LIKE')
        wrapper.like(StringUtils.isNotBlank(query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}()), ${className}::get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}, query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}());
#end
#end
#end
        return wrapper;
    }

#if(${hasTreeConfig})
    private List<${tree.className}> build${tree.className}Tree(List<${tree.className}> rows) {
        Map<String, ${tree.className}> nodeMap = new LinkedHashMap<>();
        for (${tree.className} row : rows) {
            String key = normalizeTreeKey(row.get${tree.keyFieldCap}());
            if (StringUtils.isBlank(key)) {
                continue;
            }
            row.set${tree.childrenFieldCap}(new ArrayList<>());
            nodeMap.put(key, row);
        }

        List<${tree.className}> roots = new ArrayList<>();
        for (${tree.className} row : nodeMap.values()) {
            String key = normalizeTreeKey(row.get${tree.keyFieldCap}());
            String parentKey = normalizeTreeKey(row.get${tree.parentFieldCap}());
            ${tree.className} parent = nodeMap.get(parentKey);
            if (isRootTreeParent(parentKey) || parent == null || key.equals(parentKey)) {
                roots.add(row);
                continue;
            }
            parent.get${tree.childrenFieldCap}().add(row);
        }
        normalize${tree.className}TreeLeafState(roots);
        return roots;
    }

    private void mark${tree.className}LeafState(List<${tree.className}> rows) {
        for (${tree.className} row : rows) {
            LambdaQueryWrapper<${tree.className}> childWrapper = new LambdaQueryWrapper<>();
            childWrapper.eq(${tree.className}::get${tree.parentFieldCap}, row.get${tree.keyFieldCap}());
            row.setIsLeaf(${tree.mapperVarName}.selectCount(childWrapper) <= 0);
        }
    }

    private void normalize${tree.className}TreeLeafState(List<${tree.className}> nodes) {
        for (${tree.className} node : nodes) {
            List<${tree.className}> children = node.get${tree.childrenFieldCap}();
            if (children != null && !children.isEmpty()) {
                node.setIsLeaf(false);
                normalize${tree.className}TreeLeafState(children);
            } else {
                node.setIsLeaf(true);
            }
        }
    }

    private boolean isRootTreeParent(String parentKey) {
        return StringUtils.isBlank(parentKey) || "0".equals(parentKey) || "null".equalsIgnoreCase(parentKey);
    }

    private String normalizeTreeKey(Object value) {
        if (value == null) {
            return null;
        }
        String key = String.valueOf(value);
        return StringUtils.isBlank(key) ? null : key;
    }

#end
#if(${isMasterDetailLayout})
    private List<Map<String, Object>> resolveChildRows(${className}MasterDetailDTO dto, String childKey) {
        if (dto == null || dto.getChildren() == null || dto.getChildren().get(childKey) == null) {
            return List.of();
        }
        return dto.getChildren().get(childKey);
    }

#foreach($child in $masterDetailChildren)
    private Object resolve${child.className}RelationValue(${className} main, Object fallbackId) {
        Object value = main == null ? null : main.get${child.mainFieldCap}();
        return value == null ? fallbackId : value;
    }

    private void clear${child.className}Rows(Object relationValue) {
        if (relationValue == null) {
            return;
        }
        LambdaQueryWrapper<${child.className}> wrapper = new LambdaQueryWrapper<>();
        wrapper.eq(${child.className}::get${child.childFkFieldCap}, relationValue);
        ${child.mapperVarName}.delete(wrapper);
    }

    private void save${child.className}Rows(List<Map<String, Object>> rows, Object relationValue) {
        if (relationValue == null || rows == null || rows.isEmpty()) {
            return;
        }
        for (Map<String, Object> row : rows) {
            ${child.className} entity = BeanUtil.toBean(row, ${child.className}.class);
#if($child.pkColumn)
            BeanUtil.setProperty(entity, "${child.pkColumn.javaField}", null);
#end
            BeanUtil.setProperty(entity, "${child.childFkField}", relationValue);
            ${child.mapperVarName}.insert(entity);
        }
    }

#end
#end
}
