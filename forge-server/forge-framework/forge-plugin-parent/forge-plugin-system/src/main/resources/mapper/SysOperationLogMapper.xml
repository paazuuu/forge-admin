<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.system.mapper.SysOperationLogMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.system.entity.SysOperationLog">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="operator_name" property="operatorName"/>
        <result column="operation_module" property="operationModule"/>
        <result column="operation_type" property="operationType"/>
        <result column="operation_desc" property="operationDesc"/>
        <result column="operation_page" property="operationPage"/>
        <result column="operation_page_title" property="operationPageTitle"/>
        <result column="operation_content" property="operationContent"/>
        <result column="request_method" property="requestMethod"/>
        <result column="request_url" property="requestUrl"/>
        <result column="request_params" property="requestParams"/>
        <result column="response_result" property="responseResult"/>
        <result column="before_data" property="beforeData"/>
        <result column="after_data" property="afterData"/>
        <result column="diff_data" property="diffData"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="operation_status" property="operationStatus"/>
        <result column="operation_ip" property="operationIp"/>
        <result column="operation_location" property="operationLocation"/>
        <result column="user_agent" property="userAgent"/>
        <result column="execute_time" property="executeTime"/>
        <result column="operation_time" property="operationTime"/>
    </resultMap>

    <sql id="Base_Columns">
        id,
        tenant_id,
        user_id,
        username,
        operator_name,
        operation_module,
        operation_type,
        operation_desc,
        operation_page,
        operation_page_title,
        operation_content,
        request_method,
        request_url,
        request_params,
        response_result,
        before_data,
        after_data,
        diff_data,
        error_msg,
        operation_status,
        operation_ip,
        operation_location,
        user_agent,
        execute_time,
        operation_time
    </sql>

    <sql id="Query_Condition">
        <where>
            <if test="query != null">
                <if test="query.username != null and query.username != ''">
                    AND username LIKE CONCAT('%', #{query.username}, '%')
                </if>
                <if test="query.operatorName != null and query.operatorName != ''">
                    AND operator_name LIKE CONCAT('%', #{query.operatorName}, '%')
                </if>
                <if test="query.operationModule != null and query.operationModule != ''">
                    AND operation_module LIKE CONCAT('%', #{query.operationModule}, '%')
                </if>
                <if test="query.operationType != null and query.operationType != ''">
                    <choose>
                        <when test="query.operationType == 'ADD'">
                            AND operation_type IN ('ADD', 'INSERT')
                        </when>
                        <otherwise>
                            AND operation_type = #{query.operationType}
                        </otherwise>
                    </choose>
                </if>
                <if test="query.operationStatus != null">
                    AND operation_status = #{query.operationStatus}
                </if>
                <if test="query.operationIp != null and query.operationIp != ''">
                    AND operation_ip LIKE CONCAT('%', #{query.operationIp}, '%')
                </if>
                <if test="query.requestUrl != null and query.requestUrl != ''">
                    AND request_url LIKE CONCAT('%', #{query.requestUrl}, '%')
                </if>
                <if test="query.requestParams != null and query.requestParams != ''">
                    AND request_params LIKE CONCAT('%', #{query.requestParams}, '%')
                </if>
                <if test="query.operationPage != null and query.operationPage != ''">
                    AND operation_page LIKE CONCAT('%', #{query.operationPage}, '%')
                </if>
                <if test="query.operationPageTitle != null and query.operationPageTitle != ''">
                    AND operation_page_title LIKE CONCAT('%', #{query.operationPageTitle}, '%')
                </if>
                <if test="query.operationContent != null and query.operationContent != ''">
                    AND operation_content LIKE CONCAT('%', #{query.operationContent}, '%')
                </if>
                <if test="query.startTime != null and query.startTime != ''">
                    AND operation_time &gt;= #{query.startTime}
                </if>
                <if test="query.endTime != null and query.endTime != ''">
                    AND operation_time &lt;= #{query.endTime}
                </if>
            </if>
        </where>
    </sql>

    <select id="selectOperationLogPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM sys_operation_log
        <include refid="Query_Condition"/>
        ORDER BY operation_time DESC, id DESC
    </select>

    <select id="selectOperationLogDetail" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM sys_operation_log
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectOperationLogExportList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM sys_operation_log
        <include refid="Query_Condition"/>
        ORDER BY operation_time DESC, id DESC
        LIMIT 50000
    </select>

</mapper>
