<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.system.mapper.SysPostMapper">

    <sql id="PostListSelect">
        SELECT
            p.id,
            p.tenant_id,
            p.post_code,
            p.org_id,
            o.org_name,
            p.post_name,
            p.post_status,
            p.post_type,
            p.sort,
            p.remark,
            p.create_by,
            p.create_time,
            p.create_dept,
            p.update_by,
            p.update_time
        FROM sys_post p
        LEFT JOIN sys_org o ON o.id = p.org_id AND o.tenant_id = p.tenant_id
    </sql>

    <sql id="PostListWhere">
        <where>
            <if test="query != null and query.tenantId != null">
                AND p.tenant_id = #{query.tenantId}
            </if>
            <if test="query != null and query.postCode != null and query.postCode != ''">
                AND p.post_code = #{query.postCode}
            </if>
            <if test="query != null and query.orgId != null">
                AND p.org_id = #{query.orgId}
            </if>
            <if test="query != null and query.postName != null and query.postName != ''">
                AND p.post_name LIKE CONCAT('%', #{query.postName}, '%')
            </if>
            <if test="query != null and query.postStatus != null">
                AND p.post_status = #{query.postStatus}
            </if>
            <if test="query != null and query.postType != null">
                AND p.post_type = #{query.postType}
            </if>
        </where>
    </sql>

    <select id="selectPostPage" resultType="com.mdframe.forge.plugin.system.entity.SysPost">
        <include refid="PostListSelect" />
        <include refid="PostListWhere" />
        ORDER BY p.sort ASC, p.create_time DESC
    </select>

    <select id="selectPostList" resultType="com.mdframe.forge.plugin.system.entity.SysPost">
        <include refid="PostListSelect" />
        <include refid="PostListWhere" />
        ORDER BY p.sort ASC, p.create_time DESC
    </select>

</mapper>
