<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.starter.flow.mapper.FlowCcMapper">

    <!-- 工作台未读抄送数。 -->
    <select id="countWorkspaceUnread" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM sys_flow_cc c
        WHERE c.cc_user_id = #{userId}
          AND c.is_read = 0
    </select>

</mapper>
