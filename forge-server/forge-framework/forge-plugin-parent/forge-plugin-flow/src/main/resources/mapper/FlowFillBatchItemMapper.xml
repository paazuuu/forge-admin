<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.starter.flow.mapper.FlowFillBatchItemMapper">

    <select id="selectByBatchId" resultType="com.mdframe.forge.starter.flow.entity.FlowFillBatchItem">
        SELECT i.*
        FROM sys_flow_fill_batch_item i
        WHERE i.deleted = 0
          AND i.batch_id = #{batchId}
        ORDER BY i.create_time ASC
    </select>

    <select id="selectByIdForUpdate" resultType="com.mdframe.forge.starter.flow.entity.FlowFillBatchItem">
        SELECT i.*
        FROM sys_flow_fill_batch_item i
        WHERE i.deleted = 0
          AND i.id = #{id}
        LIMIT 1
        FOR UPDATE
    </select>
</mapper>
