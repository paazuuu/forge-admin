<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.starter.flow.mapper.FlowBusinessMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.starter.flow.entity.FlowBusiness">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="business_key" property="businessKey"/>
        <result column="business_type" property="businessType"/>
        <result column="process_instance_id" property="processInstanceId"/>
        <result column="process_def_id" property="processDefId"/>
        <result column="process_def_key" property="processDefKey"/>
        <result column="title" property="title"/>
        <result column="status" property="status"/>
        <result column="apply_user_id" property="applyUserId"/>
        <result column="apply_user_name" property="applyUserName"/>
        <result column="apply_dept_id" property="applyDeptId"/>
        <result column="apply_dept_name" property="applyDeptName"/>
        <result column="apply_time" property="applyTime"/>
        <result column="end_time" property="endTime"/>
        <result column="duration" property="duration"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Columns">
        id,
        tenant_id,
        business_key,
        business_type,
        process_instance_id,
        process_def_id,
        process_def_key,
        title,
        status,
        apply_user_id,
        apply_user_name,
        apply_dept_id,
        apply_dept_name,
        apply_time,
        end_time,
        duration,
        create_time,
        update_time
    </sql>

    <select id="selectByProcessInstanceId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM sys_flow_business
        WHERE process_instance_id = #{processInstanceId}
        LIMIT 1
    </select>

    <select id="selectByBusinessKey" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM sys_flow_business
        WHERE business_key = #{businessKey}
        ORDER BY create_time DESC, id DESC
        LIMIT 1
    </select>

    <select id="selectByBusinessKeyAndTenantId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Columns"/>
        FROM sys_flow_business
        WHERE tenant_id = #{tenantId}
          AND business_key = #{businessKey}
        LIMIT 1
    </select>
</mapper>
