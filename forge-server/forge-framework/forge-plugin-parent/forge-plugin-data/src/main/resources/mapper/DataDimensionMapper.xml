<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.data.mapper.DataDimensionMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.data.entity.DataDimension">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="dimension_code" property="dimensionCode"/>
        <result column="dimension_name" property="dimensionName"/>
        <result column="source_type" property="sourceType"/>
        <result column="connection_id" property="connectionId"/>
        <result column="connection_name" property="connectionName"/>
        <result column="sql_text" property="sqlText"/>
        <result column="value_column" property="valueColumn"/>
        <result column="label_column" property="labelColumn"/>
        <result column="status" property="status"/>
        <result column="last_sync_time" property="lastSyncTime"/>
        <result column="description" property="description"/>
        <result column="item_count" property="itemCount"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="create_dept" property="createDept"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="DimensionSelect">
        SELECT d.*,
               c.connection_name,
               COALESCE(item_stat.item_count, 0) AS item_count
        FROM ai_report_data_dimension d
        LEFT JOIN ai_report_data_connection c
            ON d.connection_id = c.id
            AND c.tenant_id = #{tenantId}
        LEFT JOIN (
            SELECT tenant_id, dimension_id, COUNT(1) AS item_count
            FROM ai_report_data_dimension_item
            WHERE tenant_id = #{tenantId}
            GROUP BY tenant_id, dimension_id
        ) item_stat
            ON item_stat.tenant_id = d.tenant_id
            AND item_stat.dimension_id = d.id
    </sql>

    <select id="selectDimensionPage" resultMap="BaseResultMap">
        <include refid="DimensionSelect"/>
        WHERE d.tenant_id = #{tenantId}
        <if test="dimensionName != null and dimensionName != ''">
            AND (d.dimension_name LIKE CONCAT('%', #{dimensionName}, '%')
                OR d.dimension_code LIKE CONCAT('%', #{dimensionName}, '%'))
        </if>
        <if test="sourceType != null and sourceType != ''">
            AND d.source_type = #{sourceType}
        </if>
        <if test="status != null">
            AND d.status = #{status}
        </if>
        ORDER BY d.create_time DESC
    </select>

    <select id="selectDimensionList" resultMap="BaseResultMap">
        <include refid="DimensionSelect"/>
        WHERE d.tenant_id = #{tenantId}
        <if test="status != null">
            AND d.status = #{status}
        </if>
        ORDER BY d.dimension_name ASC, d.id ASC
    </select>

    <select id="selectDimensionByIds" resultMap="BaseResultMap">
        <include refid="DimensionSelect"/>
        WHERE d.tenant_id = #{tenantId}
          AND d.id IN
          <foreach collection="dimensionIds" item="dimensionId" open="(" separator="," close=")">
              #{dimensionId}
          </foreach>
        ORDER BY d.dimension_name ASC, d.id ASC
    </select>

    <select id="selectDimensionByCode" resultMap="BaseResultMap">
        SELECT *
        FROM ai_report_data_dimension
        WHERE tenant_id = #{tenantId}
          AND dimension_code = #{dimensionCode}
        LIMIT 1
    </select>
</mapper>
