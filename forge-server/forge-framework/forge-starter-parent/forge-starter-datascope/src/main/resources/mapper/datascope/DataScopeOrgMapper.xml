<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.starter.datascope.mapper.DataScopeOrgMapper">

    <select id="selectAllOrgAncestors" resultType="com.mdframe.forge.starter.datascope.model.DataScopeOrgInfo">
        SELECT
            id AS orgId,
            ancestors
        FROM sys_org
        WHERE del_flag = 0
    </select>

</mapper>
