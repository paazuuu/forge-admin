<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.starter.datascope.mapper.SysRoleDataScopeMapper">

    <resultMap id="SysRoleDataScopeResultMap" type="com.mdframe.forge.starter.datascope.entity.SysRoleDataScope">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="roleId" column="role_id"/>
        <result property="orgId" column="org_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectAllRoleDataScopes" resultMap="SysRoleDataScopeResultMap">
        SELECT
            id,
            tenant_id,
            role_id,
            org_id,
            create_time
        FROM sys_role_data_scope
    </select>

</mapper>
