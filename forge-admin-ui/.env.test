# 测试环境配置
# 静态资源目录
VITE_PUBLIC_PATH=/forge

# 路由前缀
VITE_BASE_URL=/forge

# map文件
VITE_DEVTOOL=none

# 请求地址前缀
VITE_REQUEST_PREFIX=/forge-api

# 主服务代理地址（生产环境由Nginx代理，此处留空）
VITE_HTTP_PROXY_TARGET=

# 流程服务代理地址（生产环境由Nginx代理，此处留空）
VITE_FLOW_PROXY_TARGET=

# 报表子系统单点登录配置
VITE_SSO_BRIDGE_ROUTE=/report/design
VITE_SSO_TARGET_CLIENT=forge_report
VITE_SSO_TARGET_BASE_URLS={"forge_report":"http://81.70.22.48:8084/forge-report"}
VITE_SSO_DEFAULT_REDIRECTS={"forge_report":"/project/items"}
VITE_REPORT_UI_BASE_URL=http://81.70.22.48:8084/forge-report
VITE_REPORT_UI_DEFAULT_REDIRECT=/project/items
VITE_REPORT_UI_HOST_FALLBACK=81.70.22.48:8084
VITE_REPORT_UI_PATH_PREFIX=/forge-report
