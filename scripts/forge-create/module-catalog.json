{
  "presets": {
    "minimal-admin": {
      "description": "最小后台：系统权限、租户、文件、基础认证、代码生成和管理端前端。",
      "roots": [
        "admin-server",
        "admin-ui",
        "plugin-system",
        "plugin-generator"
      ]
    },
    "data-app": {
      "description": "数据应用：minimal-admin + 数据资产/数据集模块。",
      "roots": [
        "admin-server",
        "admin-ui",
        "plugin-system",
        "plugin-data"
      ]
    },
    "ai-report": {
      "description": "AI 数据大屏：data-app + AI、外部接口代理、报表服务和报表前端。",
      "roots": [
        "admin-server",
        "report-server",
        "admin-ui",
        "report-ui",
        "plugin-system",
        "plugin-data",
        "plugin-ai",
        "plugin-external"
      ]
    },
    "full": {
      "description": "全量能力：保留当前 Forge 后端所有子模块和两个前端工程。",
      "roots": [
        "admin-server",
        "report-server",
        "app-server",
        "business-core",
        "flow-client",
        "flow-server",
        "admin-ui",
        "report-ui",
        "plugin-system",
        "plugin-job",
        "plugin-message",
        "plugin-flow",
        "plugin-generator",
        "plugin-ai",
        "plugin-external",
        "plugin-data",
        "starter-idempotent"
      ]
    }
  },
