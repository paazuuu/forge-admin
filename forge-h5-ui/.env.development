# 开发环境配置
# 端口号
VITE_HTTP_PORT=3001

# 请求地址前缀
VITE_REQUEST_PREFIX=/dev-api

# 图片host地址
VITE_RESOURCE_HOST=/

# 模板文件下载地址
VITE_TEMPLATE_PATH=/templates

# Forge App 服务代理地址（H5 默认连接 app-server）
VITE_HTTP_PROXY_TARGET=http://127.0.0.1:8583/

# Flowable 流程服务代理地址（待办、审批处理）
VITE_FLOW_PROXY_TARGET=http://127.0.0.1:8081/

# 客户端配置
VITE_USER_CLIENT=h5
VITE_APP_ID=forge_h5
VITE_APP_SECRET=forge_h5123
