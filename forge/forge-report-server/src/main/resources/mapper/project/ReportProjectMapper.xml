<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.report.project.mapper.ReportProjectMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.report.project.domain.ReportProject">
        <id column="id" property="id" />
        <result column="tenant_id" property="tenantId" />
        <result column="directory_id" property="directoryId" />
        <result column="project_name" property="projectName" />
        <result column="remark" property="remark" />
        <result column="index_img" property="indexImg" />
        <result column="status" property="status" />
        <result column="canvas_width" property="canvasWidth" />
        <result column="canvas_height" property="canvasHeight" />
        <result column="background_color" property="backgroundColor" />
        <result column="component_data" property="componentData" />
        <result column="publish_status" property="publishStatus" />
        <result column="publish_url" property="publishUrl" />
        <result column="publish_time" property="publishTime" />
        <result column="create_dept" property="createDept" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="Base_Column_List">
        id, tenant_id, directory_id, project_name, remark, index_img, status,
        canvas_width, canvas_height, background_color, component_data,
        publish_status, publish_url, publish_time,
        create_dept, create_by, create_time, update_by, update_time
    </sql>

    <select id="selectProjectPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM ai_report_project
        <where>
            <if test="projectName != null and projectName != ''">
                AND project_name LIKE CONCAT('%', #{projectName}, '%')
            </if>
            <if test="directoryIds != null and directoryIds.size() > 0">
                AND directory_id IN
                <foreach collection="directoryIds" item="directoryId" open="(" separator="," close=")">
                    #{directoryId}
                </foreach>
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="countByDirectoryIds" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM ai_report_project
        <where>
            <if test="directoryIds != null and directoryIds.size() > 0">
                directory_id IN
                <foreach collection="directoryIds" item="directoryId" open="(" separator="," close=")">
                    #{directoryId}
                </foreach>
            </if>
            <if test="directoryIds == null or directoryIds.size() == 0">
                1 = 0
            </if>
        </where>
    </select>

    <select id="selectFileIdByImageReference" resultType="java.lang.String">
        SELECT file_id
        FROM sys_file_metadata
        <where>
            status = 1
            AND (
                file_id = #{rawValue}
                OR access_url = #{rawValue}
                <if test="objectKey != null and objectKey != ''">
                    OR file_path = #{objectKey}
                    OR storage_name = #{objectKey}
                </if>
            )
        </where>
        ORDER BY upload_time DESC
        LIMIT 1
    </select>

</mapper>
