/**
 * ${tableComment} API
 * 生成日期: ${date}
 */
import { request } from '@/utils'

const BASE = '${apiBase}'

/** 分页查询 */
export function get${apiVarName}Page(params) {
  return request.get(BASE + '/page', { params })
}

#if(${hasTreeConfig})
/** 查询树形数据 */
export function get${apiVarName}Tree(params) {
  return request.get(BASE + '/tree', { params })
}

#end
/** 查询详情 */
export function get${apiVarName}Detail(${pkColumn.javaField}) {
  return request.post(BASE + '/getById', null, { params: { ${pkColumn.javaField} } })
}

/** 新增 */
export function create${apiVarName}(data) {
  return request.post(BASE + '/add', data)
}

/** 更新 */
export function update${apiVarName}(data) {
  return request.post(BASE + '/edit', data)
}

/** 删除 */
export function remove${apiVarName}(${pkColumn.javaField}) {
  return request.post(BASE + '/remove/' + ${pkColumn.javaField})
}
